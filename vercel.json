{
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/request-otp",             "destination": "/api/auth?action=request-otp" },
    { "source": "/api/verify-otp",              "destination": "/api/auth?action=verify-otp" },
    { "source": "/api/reset-password",           "destination": "/api/auth?action=reset-password" },
    { "source": "/api/change-password",          "destination": "/api/auth?action=change-password" },
    { "source": "/api/register-school",          "destination": "/api/registration?action=register-school" },
    { "source": "/api/verify-registration-otp",  "destination": "/api/registration?action=verify-registration-otp" },
    { "source": "/api/create-school-account",    "destination": "/api/registration?action=create-school-account" },
    { "source": "/api/create-payment",           "destination": "/api/payments?action=create-payment" },
    { "source": "/api/verify-payment",           "destination": "/api/payments?action=verify-payment" },
    { "source": "/api/payments/webhook",         "destination": "/api/payments?action=webhook" },
    { "source": "/api/payments/refund",          "destination": "/api/payments?action=refund" },
    { "source": "/api/payments/history",         "destination": "/api/payments?action=history" },
    { "source": "/api/payments/invoice",         "destination": "/api/payments?action=invoice" },
    { "source": "/api/:path*",                   "destination": "/api/:path*" },
    { "source": "/(.*)",                         "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "https://www.aegiserp.xyz" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,x-razorpay-signature" },
        { "key": "X-Content-Type-Options",       "value": "nosniff" },
        { "key": "X-Frame-Options",              "value": "DENY" },
        { "key": "X-XSS-Protection",             "value": "1; mode=block" }
      ]
    }
  ]
}
